---
import { promises as fs } from "node:fs";
import path from "node:path";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";

interface DraftEntry {
  slug: string;
  title: string;
  description: string;
  pubDatetime: string;
}

async function loadDrafts(): Promise<DraftEntry[]> {
  const postsDir = path.resolve(process.cwd(), "src", "content", "posts");
  let files: string[] = [];
  try {
    files = await fs.readdir(postsDir);
  } catch {
    return [];
  }

  const drafts: DraftEntry[] = [];
  for (const name of files) {
    if (!name.endsWith(".md")) continue;
    const filePath = path.join(postsDir, name);
    const raw = await fs.readFile(filePath, "utf8");
    if (!/^draft:\s*true\s*$/m.test(raw)) continue;

    const titleMatch = raw.match(/^title:\s*["']?(.+?)["']?\s*$/m);
    const descMatch = raw.match(/^description:\s*["']?(.+?)["']?\s*$/m);
    const dateMatch = raw.match(/^pubDatetime:\s*(.+?)\s*$/m);
    drafts.push({
      slug: name.replace(/\.md$/, ""),
      title: titleMatch?.[1] ?? name,
      description: descMatch?.[1] ?? "",
      pubDatetime: dateMatch?.[1] ?? "",
    });
  }

  drafts.sort((a, b) => (a.pubDatetime < b.pubDatetime ? 1 : -1));
  return drafts;
}

const isDev = import.meta.env.DEV;
const drafts = isDev ? await loadDrafts() : [];
---

<Layout title="Drafts">
  <Header />
  <main id="main-content" class="app-layout">
    <section class="mx-auto max-w-3xl px-4 py-12">
      <h1 class="text-3xl font-semibold tracking-wide">Drafts</h1>
      <p class="text-foreground/70 mt-2 text-sm">
        {
          isDev
            ? "초안 글 목록입니다. 발행 버튼을 누르면 frontmatter 가 draft:false 로 바뀌고 자동으로 commit·push 됩니다."
            : "이 페이지는 로컬 dev 모드(npm run dev)에서만 동작합니다."
        }
      </p>

      {
        isDev && drafts.length === 0 && (
          <p class="text-foreground/60 mt-12 text-center">
            draft 글이 없습니다.
          </p>
        )
      }

      {
        isDev && drafts.length > 0 && (
          <ul class="mt-8 space-y-6">
            {drafts.map(draft => (
              <li class="border-border rounded-md border p-4">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1">
                    <h2 class="text-lg font-semibold">{draft.title}</h2>
                    <p class="text-foreground/60 mt-1 font-mono text-xs">
                      {draft.slug}
                    </p>
                    {draft.description && (
                      <p class="text-foreground/80 mt-2 text-sm">
                        {draft.description}
                      </p>
                    )}
                  </div>
                  <button
                    type="button"
                    data-publish-slug={draft.slug}
                    class="border-border hover:bg-accent shrink-0 cursor-pointer rounded border px-3 py-1.5 text-sm font-medium transition"
                  >
                    발행하기
                  </button>
                </div>
                <a
                  href={`/posts/${draft.slug}/`}
                  class="text-foreground/60 hover:text-foreground mt-3 inline-block text-xs underline"
                >
                  미리보기 →
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-publish-slug]").forEach(
    button => {
      button.addEventListener("click", async () => {
        const slug = button.dataset.publishSlug;
        if (!slug) return;
        if (!confirm(`"${slug}" 글을 발행할까요? (commit + push 즉시 실행)`)) {
          return;
        }
        const original = button.textContent;
        button.disabled = true;
        button.textContent = "발행 중…";
        try {
          const res = await fetch("/__publish", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify({ slug }),
          });
          const data = await res.json();
          if (!data.ok) {
            alert(`실패: ${data.error}`);
            button.disabled = false;
            button.textContent = original;
            return;
          }
          button.textContent = "발행 완료";
          setTimeout(() => location.reload(), 800);
        } catch (err) {
          alert(`네트워크 오류: ${err instanceof Error ? err.message : err}`);
          button.disabled = false;
          button.textContent = original;
        }
      });
    },
  );
</script>
